# Local Postgres — copy to .env and adjust.
#
# Homebrew on macOS: default DB user is your Mac login (`whoami`), not "postgres".
# Example: postgresql+psycopg2://swlsf23@127.0.0.1:5432/website
DATABASE_URL=postgresql+psycopg2://YOUR_MAC_USERNAME@127.0.0.1:5432/website

# Production: comma-separated origins allowed to call the API from the browser (CORS).
# Local Vite ports are always allowed; add your CloudFront / custom domain here.
# CORS_ORIGINS=https://d111111abcdef8.cloudfront.net,https://yourdomain.com
