# Copy to terraform.tfvars (gitignored) and set a globally unique bucket name.
aws_region        = "us-east-1"
spa_bucket_name   = "yourname-website-spa"
project           = "website"

# Optional: custom domain (ACM + Route 53 aliases). Requires apex -> zone id in Route 53.
# custom_domain_aliases = ["example.com", "www.example.com"]
# route53_zone_ids = { "example.com" = "Z..." }

# Optional: GitHub Actions OIDC deploy role (see infra/README.md). Example:
# github_actions_repository = "myorg/my-website"
# github_actions_branch     = "main"
